<%- include('partials/head') %>

    <div class="app-root">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="app-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-gamepad2-icon lucide-gamepad-2">
                        <line x1="6" x2="10" y1="11" y2="11" />
                        <line x1="8" x2="8" y1="9" y2="13" />
                        <line x1="15" x2="15.01" y1="12" y2="12" />
                        <line x1="18" x2="18.01" y1="10" y2="10" />
                        <path
                            d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z" />
                    </svg>
                </div>
                <span class="sidebar-title">GamePanel</span>
            </div>
            <div class="sidebar-content">
                <a class="sidebar-item active" href="/dashboard">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-layout-grid-icon lucide-layout-grid sidebar-item-icon">
                        <rect width="7" height="7" x="3" y="3" rx="1" />
                        <rect width="7" height="7" x="14" y="3" rx="1" />
                        <rect width="7" height="7" x="14" y="14" rx="1" />
                        <rect width="7" height="7" x="3" y="14" rx="1" />
                    </svg>
                    <span class="sidebar-item-label">Pulpit</span>
                </a>
                <a class="sidebar-item" href="/games">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-gamepad2-icon lucide-gamepad-2 sidebar-item-icon">
                        <line x1="6" x2="10" y1="11" y2="11" />
                        <line x1="8" x2="8" y1="9" y2="13" />
                        <line x1="15" x2="15.01" y1="12" y2="12" />
                        <line x1="18" x2="18.01" y1="10" y2="10" />
                        <path
                            d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z" />
                    </svg>
                    <span class="sidebar-item-label">Gry</span>
                </a>
                <a class="sidebar-item" href="/achievements">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        class="lucide lucide-trophy-icon lucide-trophy">
                        <path d="M10 14.66v1.626a2 2 0 0 1-.976 1.696A5 5 0 0 0 7 21.978" />
                        <path d="M14 14.66v1.626a2 2 0 0 0 .976 1.696A5 5 0 0 1 17 21.978" />
                        <path d="M18 9h1.5a1 1 0 0 0 0-5H18" />
                        <path d="M4 22h16" />
                        <path d="M6 9a6 6 0 0 0 12 0V3a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1z" />
                        <path d="M6 9H4.5a1 1 0 0 1 0-5H6" />
                    </svg>
                    <span class="sidebar-item-label">Osiągnięcia</span>
                </a>
            </div>
        </aside>
        <main class="main">
            <header class="header">
                <div class="header-content">
                    <span class="header-title">Pulpit</span>
                    <div class="header-steam-status" id="steamSyncBtn" role="button" tabindex="0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                            class="bi bi-steam" viewBox="0 0 16 16">
                            <path
                                d="M.329 10.333A8.01 8.01 0 0 0 7.99 16C12.414 16 16 12.418 16 8s-3.586-8-8.009-8A8.006 8.006 0 0 0 0 7.468l.003.006 4.304 1.769A2.2 2.2 0 0 1 5.62 8.88l1.96-2.844-.001-.04a3.046 3.046 0 0 1 3.042-3.043 3.046 3.046 0 0 1 3.042 3.043 3.047 3.047 0 0 1-3.111 3.044l-2.804 2a2.223 2.223 0 0 1-3.075 2.11 2.22 2.22 0 0 1-1.312-1.568L.33 10.333Z" />
                            <path
                                d="M4.868 12.683a1.715 1.715 0 0 0 1.318-3.165 1.7 1.7 0 0 0-1.263-.02l1.023.424a1.261 1.261 0 1 1-.97 2.33l-.99-.41a1.7 1.7 0 0 0 .882.84Zm3.726-6.687a2.03 2.03 0 0 0 2.027 2.029 2.03 2.03 0 0 0 2.027-2.029 2.03 2.03 0 0 0-2.027-2.027 2.03 2.03 0 0 0-2.027 2.027m2.03-1.527a1.524 1.524 0 1 1-.002 3.048 1.524 1.524 0 0 1 .002-3.048" />
                        </svg>
                        <span class="header-steam-status-text">
                            <%= syncLabel %>
                        </span>
                        <span class="header-steam-status-indicator <%= syncStatus %>"></span>
                    </div>
                    <div class="header-user">
                        <img class="header-user-avatar" src="<%= user.avatar_url %>" alt="Avatar użytkownika">
                        <span class="header-user-name">
                            <%= user.username %>
                        </span>
                        <div class="header-logout-btn" onclick="window.location.href='/auth/logout'">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" class="lucide lucide-door-open-icon lucide-door-open">
                                <path d="M11 20H2" />
                                <path
                                    d="M11 4.562v16.157a1 1 0 0 0 1.242.97L19 20V5.562a2 2 0 0 0-1.515-1.94l-4-1A2 2 0 0 0 11 4.561z" />
                                <path d="M11 4H8a2 2 0 0 0-2 2v14" />
                                <path d="M14 12h.01" />
                                <path d="M22 20h-3" />
                            </svg>
                        </div>
                    </div>
                </div>
            </header>
            <content class="main-content">
                <div class="content-header">
                    <span class="content-title">Witaj, <%= user.username %></span>
                    <span class="content-subtitle">
                        <%= lastSync ? 'Ostatnia synchronizacja: ' + lastSync.toLocaleDateString('pl-PL') + ' ' +
                            lastSync.toLocaleTimeString('pl-PL', { hour: '2-digit' , minute: '2-digit' })
                            : 'Brak synchronizacji — kliknij przycisk Steam, aby zsynchronizować' %>
                    </span>
                </div>

                <%# ── Karta statystyk ── %>
                    <div class="stats-cards-grid">
                        <div class="stat-card-ach">
                            <div class="stat-card-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path
                                        d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z" />
                                </svg>
                            </div>
                            <div class="stat-card-info">
                                <span class="stat-card-label">Gier w bibliotece</span>
                                <span class="stat-card-value">
                                    <%= games.length %>
                                </span>
                            </div>
                        </div>
                        <div class="stat-card-ach">
                            <div class="stat-card-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M12 6v6l4 2" />
                                </svg>
                            </div>
                            <div class="stat-card-info">
                                <span class="stat-card-label">Łącznie godzin</span>
                                <span class="stat-card-value">
                                    <%= totalHours %>
                                </span>
                            </div>
                        </div>
                        <div class="stat-card-ach">
                            <div class="stat-card-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M20 6 9 17l-5-5" />
                                </svg>
                            </div>
                            <div class="stat-card-info">
                                <span class="stat-card-label">Osiągnięcia</span>
                                <span class="stat-card-value">
                                    <%= unlockedSum %> / <%= totalSum %>
                                </span>
                            </div>
                        </div>
                        <div class="stat-card-ach">
                            <div class="stat-card-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M10 14.66v1.626a2 2 0 0 1-.976 1.696A5 5 0 0 0 7 21.978" />
                                    <path d="M14 14.66v1.626a2 2 0 0 0 .976 1.696A5 5 0 0 1 17 21.978" />
                                    <path d="M18 9h1.5a1 1 0 0 0 0-5H18" />
                                    <path d="M4 22h16" />
                                    <path d="M6 9a6 6 0 0 0 12 0V3a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1z" />
                                    <path d="M6 9H4.5a1 1 0 0 1 0-5H6" />
                                </svg>
                            </div>
                            <div class="stat-card-info">
                                <span class="stat-card-label">Ukończone gry</span>
                                <span class="stat-card-value">
                                    <%= countByStatus.completed %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <%# ── Dwa kolumny ── %>
                        <div class="dash-grid">

                            <%# ── Lewa: Status biblioteki ── %>
                                <div class="dash-panel">
                                    <div class="dash-panel-header">
                                        <span class="dash-panel-title">Biblioteka</span>
                                        <a href="/games" class="dash-panel-link">Zobacz wszystkie →</a>
                                    </div>
                                    <div class="dash-status-list">
                                        <div class="dash-status-row">
                                            <span class="pill-status tracking"></span>
                                            <span class="dash-status-label">Śledzone</span>
                                            <span class="dash-status-count">
                                                <%= countByStatus.tracking %>
                                            </span>
                                        </div>
                                        <div class="dash-status-row">
                                            <span class="pill-status completed"></span>
                                            <span class="dash-status-label">Ukończone</span>
                                            <span class="dash-status-count">
                                                <%= countByStatus.completed %>
                                            </span>
                                        </div>
                                        <div class="dash-status-row">
                                            <span class="pill-status abandoned"></span>
                                            <span class="dash-status-label">Porzucone</span>
                                            <span class="dash-status-count">
                                                <%= countByStatus.dropped %>
                                            </span>
                                        </div>
                                        <div class="dash-status-row">
                                            <span class="pill-status not-started"></span>
                                            <span class="dash-status-label">Nierozpoczęte</span>
                                            <span class="dash-status-count">
                                                <%= countByStatus.not_played %>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="dash-panel-sub">Postęp osiągnięć</div>
                                    <div class="dash-ach-bar">
                                        <div class="dash-ach-bar-fill" style="width: <%= achPercent %>%"></div>
                                    </div>
                                    <div class="dash-ach-bar-label">
                                        <span>
                                            <%= unlockedSum %> odblokowane
                                        </span>
                                        <span>
                                            <%= achPercent %>%
                                        </span>
                                    </div>
                                </div>

                                <%# ── Prawa: Najpopularniejsze gry ── %>
                                    <div class="dash-panel">
                                        <div class="dash-panel-header">
                                            <span class="dash-panel-title">Najwięcej godzin</span>
                                        </div>
                                        <div class="dash-top-games">
                                            <% const maxPlaytime=topGames.length ? (topGames[0].playtime_forever || 1) :
                                                1; %>
                                                <% topGames.forEach(function(g, idx) { %>
                                                    <% const h=Math.round((g.playtime_forever || 0) / 60); %>
                                                        <% const barW=Math.round(((g.playtime_forever || 0) /
                                                            maxPlaytime) * 100); %>
                                                            <div class="dash-top-game-row"
                                                                onclick="window.location.href='/games/<%= g.id %>'"
                                                                style="cursor:pointer;">
                                                                <span class="dash-top-rank">
                                                                    <%= idx + 1 %>
                                                                </span>
                                                                <img class="dash-top-thumb"
                                                                    src="<%= g.header_img_url %>" alt="<%= g.title %>">
                                                                <div class="dash-top-info">
                                                                    <span class="dash-top-title">
                                                                        <%= g.title %>
                                                                    </span>
                                                                    <div class="progress-bar" style="margin-top:4px;">
                                                                        <div class="progress-fill"
                                                                            style="width:<%= barW %>%"></div>
                                                                    </div>
                                                                </div>
                                                                <span class="dash-top-hours">
                                                                    <%= h %>h
                                                                </span>
                                                            </div>
                                                            <% }); %>
                                                                <% if (!topGames.length) { %>
                                                                    <p class="no-achievements">Brak zsynchronizowanych
                                                                        gier.</p>
                                                                    <% } %>
                                        </div>
                                    </div>
                        </div>

                        <%# ── Świeżo odblokowane ── %>
                            <div class="dash-panel dash-panel--full">
                                <div class="dash-panel-header">
                                    <span class="dash-panel-title">Świeżo odblokowane</span>
                                    <a href="/achievements" class="dash-panel-link">Wszystkie osiągnięcia →</a>
                                </div>
                                <% if (recentUnlocked.length===0) { %>
                                    <p class="no-achievements">Brak odblokowanych osiągnięć.</p>
                                    <% } else { %>
                                        <div class="dash-recent-grid">
                                            <% recentUnlocked.forEach(function(ach) { const pct=ach.global_percent
                                                !=null ? ach.global_percent : null; let rarityLabel=null,
                                                rarityClass=null; if (pct !==null) { if (pct> 60) { rarityLabel =
                                                'Pospolite'; rarityClass = 'rarity-common'; }
                                                else if (pct > 20) { rarityLabel = 'Rzadkie'; rarityClass =
                                                'rarity-rare'; }
                                                else if (pct > 5) { rarityLabel = 'Bardzo rzadkie'; rarityClass =
                                                'rarity-very-rare'; }
                                                else if (pct > 1) { rarityLabel = 'Epickie'; rarityClass =
                                                'rarity-epic'; }
                                                else { rarityLabel = 'Legendarne'; rarityClass = 'rarity-legendary'; }
                                                }
                                                const unlockDate = ach.unlock_time
                                                ? new Date(ach.unlock_time).toLocaleDateString('pl-PL', { day:
                                                '2-digit', month: '2-digit', year: 'numeric' })
                                                : null;
                                                %>
                                                <div class="dash-recent-card"
                                                    onclick="window.location.href='/games/<%= ach.game_db_id %>'"
                                                    style="cursor:pointer;">
                                                    <img class="dash-recent-icon" src="<%= ach.icon_url || '' %>"
                                                        alt="<%= ach.display_name || ach.api_name %>">
                                                    <div class="dash-recent-body">
                                                        <span class="dash-recent-name">
                                                            <%= ach.display_name || ach.api_name %>
                                                        </span>
                                                        <span class="dash-recent-game">
                                                            <%= ach.game_title %>
                                                        </span>
                                                        <% if (rarityLabel) { %>
                                                            <span class="ach-rarity <%= rarityClass %>"
                                                                style="margin-top:4px;">
                                                                <%= rarityLabel %>
                                                                    <% if (pct !==null) { %><span
                                                                            class="ach-rarity-pct">
                                                                            <%= pct.toFixed(1) %>%
                                                                        </span>
                                                                        <% } %>
                                                            </span>
                                                            <% } %>
                                                    </div>
                                                    <% if (unlockDate) { %>
                                                        <span class="dash-recent-date">
                                                            <%= unlockDate %>
                                                        </span>
                                                        <% } %>
                                                </div>
                                                <% }); %>
                                        </div>
                                        <% } %>
                            </div>

            </content>
        </main>
    </div>

    <%- include('partials/modal-sync') %>

        <%- include('partials/foot') %>